# Copy to .env and fill in real values. Never commit the real .env.

# ---------- App ----------
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
API_VERSION=1.0.0
# Explicit frontend origin — required once cookies are in play (a wildcard
# origin can't be combined with credentialed/cookie requests).
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trendgriddb

# ---------- Auth / JWT ----------
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-min-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-different-secret-min-16-chars
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=10

# ---------- Account lockout ----------
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MIN=15

# ---------- Password policy ----------
PASSWORD_MAX_AGE_DAYS=90
PASSWORD_HISTORY_COUNT=5
PASSWORD_RESET_TOKEN_TTL_MIN=30

# ---------- MFA (TOTP) ----------
MFA_ISSUER=NDH Trendgrid

# ---------- Field-level encryption at rest (addresses, MFA secrets) ----------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production — the app refuses to boot without it.
ENCRYPTION_KEY=dev-only-change-me-32-characters-minimum

# ---------- CAPTCHA (login/register) ----------
CAPTCHA_PROVIDER=none
CAPTCHA_SECRET=

# ---------- IP allow / block lists (comma-separated IPs or CIDR ranges) ----------
IP_ALLOWLIST=
IP_BLOCKLIST=

# ---------- Real-time security alerting (Slack-compatible incoming webhook) ----------
SECURITY_ALERT_WEBHOOK_URL=

# ---------- Outbound email (forgot-password links) ----------
# Leave SMTP_HOST unset to no-op (emails are logged, not sent) — fine for local dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=NDH Trendgrid <no-reply@trendgrid.local>
# Public frontend origin the reset-password email links to.
FRONTEND_URL=http://localhost:3000

# ---------- Cloudinary (image storage) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=fashion-store
CLOUDINARY_ALLOWED_FORMATS=jpg,jpeg,png,webp
CLOUDINARY_MAX_FILE_SIZE_MB=5

# ---------- Pagination defaults ----------
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ---------- Commerce ----------
TAX_RATE=0.13
SHIPPING_FLAT_RATE=150
FREE_SHIPPING_THRESHOLD=5000
DEFAULT_COMMERCE_CURRENCY=NPR

# ---------- Swagger ----------
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs
