# Root-level ignore rules for the whole monorepo (Backend: Node/Express/Prisma/PostgreSQL,
# Frontend: Next.js/React, both Dockerized). Each service also has its own .gitignore for
# service-specific tooling — this file covers cross-cutting and root-level concerns.

# ---------- Dependencies ----------
node_modules/
.pnp
.pnp.js

# ---------- Build output / compiled artifacts ----------
dist/
build/
out/
.next/
*.tsbuildinfo

# ---------- Environment files (never commit real secrets) ----------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
!.env.example
!**/.env.example

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Test / coverage output ----------
coverage/
.nyc_output/

# ---------- Caches ----------
.cache/
.eslintcache
.turbo/
.parcel-cache/

# ---------- OS-generated files ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---------- Editor / IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ---------- Backup / temp files ----------
*.bak
*.orig
*.tmp
*.temp
tmp/
temp/

# ---------- Docker ----------
*.pid

# ---------- Misc ----------
*.pem
.vercel

# ---------- Academic report / coursework documentation ----------
# Kept locally, intentionally excluded from the source repository.
/report/
