# Copy to .env.development (or .env) and fill in real values. Never commit the real file.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trendgriddb
NODE_ENV=development

# Base URL of the NDH.Trendgrid.Api backend this app talks to.
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# CAPTCHA on login/register/forgot-password — pluggable, no-op when unset
# (matches the API's own CAPTCHA_PROVIDER=none default). Set both to activate;
# the API's CAPTCHA_SECRET must also be configured for it to be enforced.
NEXT_PUBLIC_CAPTCHA_PROVIDER=
NEXT_PUBLIC_CAPTCHA_SITE_KEY=
